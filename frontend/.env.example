# (권장) 백엔드 API 프록시 타겟. vite.config.ts 기본값은 http://localhost:8000.
VITE_DEV_API_TARGET=http://localhost:8000

# (선택) 무료 V2 에 `as_of_month` 를 쿼리로 강제 — 백엔드 `STATS_V2_ASSUMED_TODAY` 검증 브릿지용.
# 비우면 브라우저는 미전달, 백엔드만 «실제 오늘→직전 달 1일» 결정해 최근 월간 배치 스냅샷과 같이 간다.
# VITE_STATS_V2_ASSUMED_TODAY=2026-01-01

# DECISIONS D-007: 백엔드 `API_TOKEN` 과 동일 값. axios 가 X-Api-Token 헤더로 자동 첨부.
# 백엔드 `API_TOKEN` 이 비어 있으면 이 값도 비워 두면 된다(헤더 미전송).
# VITE_API_TOKEN=
