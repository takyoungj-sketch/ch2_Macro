# CH2 Macro — dev VPS backend/.env
# cp deploy/templates/backend.env.production.example backend/.env
# chmod 600 backend/.env

DATABASE_URL=postgresql+psycopg2://ch2app:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/land_stats

SECRET_KEY=CHANGE_ME_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# HTTPS 프론트 origin (끝 슬래시 없음). 복수: 쉼표 구분
CORS_ORIGINS=https://macro.ch2data.com

# 복합부동산 built_stats (비어 있으면 /api/built 미등록)
BUILT_DATABASE_URL=postgresql+psycopg2://ch2app:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/built_stats

# 집합부동산 collective_stats (비어 있으면 /api/collective 미등록)
COLLECTIVE_DATABASE_URL=postgresql+psycopg2://ch2app:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/collective_stats

# DECISIONS D-007 — dev VPS 에서는 반드시 설정
# 생성: openssl rand -hex 32
API_TOKEN=CHANGE_ME_API_TOKEN

# 로컬 DB MAX(as_of_month) 와 일치시킬 것
STATS_V2_DEFAULT_AS_OF_MONTH=2025-12-01

# 운영/dev VPS 에서는 비움
# STATS_V2_ASSUMED_TODAY=

# 4 GB RAM 이면 128~192. OOM 시 128
# PAID_ANALYZE_WORK_MEM_MB=128
