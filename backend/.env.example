DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/land_stats
SECRET_KEY=change_me_to_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# DECISIONS D-007: 결제·로그인 도입 전 1단 보호용 토큰.
# 값이 있으면 모든 비-/health 요청이 `X-Api-Token: <값>` 헤더를 가져야 통과한다.
# 비어 있으면 미들웨어는 비활성 (개발/로컬 모드).
# API_TOKEN=

# 무료 V2 API: 요청에 as_of_month 없을 때만 사용. 값이 있으면 그 달(1일)로 고정.
# 비우거나 이 줄을 제거하면 STATS_V2_ASSUMED_TODAY(있으면) 또는 실제 «오늘» 기준 직전 달 1일(§3).
# STATS_V2_DEFAULT_AS_OF_MONTH=2025-12-01

# 검증: 서비스 기준일을 2026-01-01로 가정할 때(직전 달 as_of = 2025-12-01, 5년 창 2021-01-01~2025-12-31).
# STATS_V2_DEFAULT_AS_OF_MONTH 가 있으면 이 값은 무시됩니다.
# STATS_V2_ASSUMED_TODAY=2026-01-01

# 프론트(Vite): `frontend/.env` 에 동일 값 — 무료 V2 호출 시 as_of_month 를 명시(선택이나 로컬 검증에 유용).
# VITE_STATS_V2_ASSUMED_TODAY=2026-01-01
