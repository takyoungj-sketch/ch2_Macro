DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/land_stats
MOLIT_API_KEY=your_api_key_here
# --- V2 사전집계 (build_stats_v2.py) ---
# --as-of 생략 시: STATS_V2_DEFAULT_AS_OF_MONTH(있으면) → else STATS_V2_ASSUMED_TODAY 기준 §3 → else 실행일 §3
# STATS_V2_DEFAULT_AS_OF_MONTH=2025-12-01
# STATS_V2_ASSUMED_TODAY=2026-01-01
# 전국 배치 시 STATS_V2_SIDO_CODE 는 비울 것 (설정 시 해당 시도만 단일 실행).
# STATS_V2_SIDO_CODE=43
# UPSERT 한 번에 커밋하는 행 수 (기본 400)
# STATS_V2_UPSERT_CHUNK=400
# 전국 배치 후 API 샘플 검증: python verify_v2_national_samples.py --as-of-month 2025-12-01
